# Backend env — copy to .env and fill for local dev.
# In Cloud Run these come from --set-env-vars and Secret Manager.

LOG_LEVEL=INFO
ENVIRONMENT=development

# Vertex AI in-project (preferred).
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=sankalp-495216
GOOGLE_CLOUD_LOCATION=asia-south1

# Firestore (same project unless overridden).
FIRESTORE_PROJECT_ID=sankalp-495216

# Cloud Storage bucket for story assets.
STORAGE_BUCKET=sankalp-assets-sankalp-495216

# Maps Platform server-side key (Phase 4+).
GOOGLE_MAPS_API_KEY=

# Fallback Gemini API key path (only if GOOGLE_GENAI_USE_VERTEXAI=false).
GOOGLE_API_KEY=
